{
  "name": "mobile",
  "private": true,
  "version": "0.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "generate-client": "openapi-ts",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.ts?(x)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@rn-primitives/avatar": "^1.5.2",
    "@rn-primitives/checkbox": "^1.5.2",
    "@rn-primitives/dialog": "^1.5.2",
    "@rn-primitives/dropdown-menu": "^1.5.2",
    "@rn-primitives/label": "^1.5.2",
    "@rn-primitives/portal": "^1.5.2",
    "@rn-primitives/select": "^1.5.2",
    "@rn-primitives/slot": "^1.5.2",
    "@rn-primitives/tabs": "^1.5.2",
    "@sentry/react-native": "~8.19.0",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.101.3",
    "axios": "1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "lucide-react-native": "^1.25.0",
    "nativewind": "4.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.82.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.1.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "~4.5.2",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.26.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "~0.21.2",
    "sonner-native": "^0.26.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@biomejs/biome": "^2.5.4",
    "@hey-api/openapi-ts": "0.73.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.17",
    "dotenv": "^17.4.2",
    "jest": "~30.4.2",
    "jest-expo": "~57.0.2",
    "typescript": "^7.0.2"
  }
}
