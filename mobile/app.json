{
	"expo": {
		"name": "FastAPI Mobile",
		"slug": "fastapi-mobile",
		"version": "0.0.0",
		"orientation": "portrait",
		"scheme": "fastapimobile",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": { "supportsTablet": true },
		"android": { "adaptiveIcon": { "backgroundColor": "#ffffff" } },
		"web": { "bundler": "metro", "output": "static" },
		"plugins": ["expo-router", "expo-secure-store", "expo-sqlite"],
		"experiments": { "typedRoutes": true, "tsconfigPaths": true },
		"extra": { "router": { "origin": false, "root": "./src/app" } }
	}
}
