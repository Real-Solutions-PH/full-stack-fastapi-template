# Domain
# This would be set to the deployed environment's domain with an env var on deployment
DOMAIN=localhost

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:3000
# In a deployed environment, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production (accepted values in backend/app/core/config.py)
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"
STACK_NAME=full-stack-fastapi-project

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:3000,https://localhost,https://localhost:3000"
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Supabase Auth (#39) — the backend verifies Supabase-issued JWTs via JWKS.
# The values below are the Supabase CLI's WELL-KNOWN local demo keys: public
# constants shipped with `supabase start` (make supabase-up), only valid
# against a local stack, and safe to commit. For a hosted project use its
# real values (see docs/runbook.md).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
# Override only when SUPABASE_URL differs from the issuer baked into the
# tokens (e.g. a containerized backend reaching the local stack through
# host.docker.internal while tokens say 127.0.0.1 — see compose.yml).
SUPABASE_JWT_ISSUER=
# The frontend browser client needs the same two values as
# NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY: compose derives
# them from SUPABASE_URL / SUPABASE_ANON_KEY above (Docker BUILD args,
# inlined into the Next.js bundle). When running `bun run dev` directly,
# export them (or put them in frontend/.env.local):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Tenancy: slug of the tenant new signups are assigned to (#38). The tenant's
# UUID is fixed by the seed/migration and is not configurable here.
DEFAULT_TENANT_SLUG=default

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changethis
MINIO_DEFAULT_BUCKET=app-uploads

# OCR Module
OCR_ENABLED=false
OCR_DEFAULT_PROVIDER=rapidocr
OCR_MAX_FILE_SIZE_MB=10
OCR_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/tiff,application/pdf
OCR_BUCKET=ocr-documents

# Error monitoring — GlitchTip DSNs (Sentry-SDK compatible; see docs/runbook.md)
# Backend DSN, read at runtime by the FastAPI app.
SENTRY_DSN=
# Frontend DSN, passed as a Docker BUILD arg (NEXT_PUBLIC_SENTRY_DSN) and
# inlined into the Next.js bundle at build time — a runtime-only value no-ops.
FRONTEND_SENTRY_DSN=
# Mobile uses EXPO_PUBLIC_SENTRY_DSN, set in mobile/.env (or EAS env), not here.

# AI Module
AI_ENABLED=false
NEXT_PUBLIC_AI_ENABLED=false

# LLM Providers (at least one required when AI_ENABLED=true)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# Default LLM provider: "nebius" or "openrouter"
DEFAULT_LLM_PROVIDER=nebius

# Tools
BRAVE_API_KEY=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
