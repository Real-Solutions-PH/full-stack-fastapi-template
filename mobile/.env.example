EXPO_PUBLIC_API_URL=http://localhost:8000
# Supabase Auth (local stack defaults; the anon key is the public
# supabase-demo key — same as SUPABASE_ANON_KEY in the root .env.example).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# GlitchTip DSN (Sentry-SDK compatible); error monitoring no-ops when unset.
EXPO_PUBLIC_SENTRY_DSN=
# Native (prebuild/EAS) builds: the Sentry expo plugin injects a source-map
# upload step that FAILS the build without an auth token. Keep uploads off
# until deliberately configured against GlitchTip.
SENTRY_DISABLE_AUTO_UPLOAD=true
